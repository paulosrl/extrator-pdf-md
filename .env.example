DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/pdfcleaner
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/pdfcleaner
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
STORAGE_PATH=/data
MAX_FILE_SIZE_MB=200
MAX_PAGES=1000
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pdfcleaner

# OpenAI direto (opcional — habilita modelo "ChatGPT")
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Azure OpenAI (opcional — habilita modelos "Azure GPT-4.1" e "Azure GPT-5")
# Não incluir /openai/v1/ no endpoint — é adicionado automaticamente
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
